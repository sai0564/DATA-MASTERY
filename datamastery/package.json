    "lucide-react": "^1.25.0",
    "motion": "^12.42.2",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^3.6.0"
